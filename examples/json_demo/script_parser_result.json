        {
          "id": "elem_002",
          "type": "action",
          "sequence": 2,
          "duration": 3.0,
          "confidence": 0.97,
          "content": "林小雨蹲在长椅旁，用手帕擦拭一本被雨水浸湿的诗集，神情焦急。",
          "character": "林小雨",
          "target_character": null,
          "description": "特写手部：素白棉质手帕反复轻按《飞鸟集》湿皱封面，纸页微卷，水痕晕染泰戈尔英文标题；她咬下唇，喉结微动，呼吸略促",
          "intensity": 0.7,
          "emotion": "anxious",
          "audio_context": {
            "sound_type": "water_drip",
            "description": "书页滴水轻响，手帕摩擦纸面沙沙声",
            "intensity": 0.25
          }
        },
        {
          "id": "elem_003",
          "type": "dialogue",
          "sequence": 3,
          "duration": 5.2,
          "confidence": 0.99,
          "content": "明明说好今天还书的……这雨下得，他会不会不来了？",
          "character": "林小雨",
          "target_character": null,
          "description": "中景侧脸：雨丝掠过她额前碎发，睫毛轻颤，声音微哽，左手无意识攥紧书脊，指节泛白",
          "intensity": 0.8,
          "emotion": "sad",
          "audio_context": {
            "sound_type": "rain",
            "description": "雨声稍弱，突出人声气声与轻微鼻音",
