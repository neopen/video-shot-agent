# 剧本分镜智能体配置示例。请复制此文件为.env并填入实际的API密钥
# 详细参考 Github: https://github.com/neopen/story-shot-agent

# ================= 应用配置 =================
# 部署环境（development, production）
PENSHOT_APP__ENVIRONMENT=development
# 剧本的语言设置，目前支持：zh（中文）或en（英文）
PENSHOT_APP__LANGUAGE=zh
# HuggingFace 镜像地址
PENSHOT_APP__HF_ENDPOINT=https://hf-mirror.com

# ================= API配置 =================
#  服务器主机，支持HOST环境变量
PENSHOT_API__HOST=localhost
#  服务器端口，支持PORT环境变量
PENSHOT_API__PORT=8000
# PENSHOT_API__RELOAD=true

########################## LLM 模型配置 #########################
# 系统支持的厂商（openai, qwen, deepseek, ollama），当默认模型不可用时使用备用厂商

# ================= LLM默认配置 =================
# LLM 厂商 API
PENSHOT_LLM__DEFAULT__BASE_URL=https://api.openai.com/v1
# LLM 厂商 KAY
PENSHOT_LLM__DEFAULT__API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
# LLM 厂商 模型
PENSHOT_LLM__DEFAULT__MODEL_NAME=gpt-4o
# 生成温度参数，控制输出的随机性： 0.0 = 确定性输出，1.0 = 最大随机性
PENSHOT_LLM__DEFAULT__TEMPERATURE=0.1
# 默认API超时时间（秒）
PENSHOT_LLM__DEFAULT__TIMEOUT=60
# 最大重试次数
PENSHOT_LLM__DEFAULT__MAX_RETRIES=3
# 最大生成令牌数
PENSHOT_LLM__DEFAULT__MAX_TOKENS=8192
PENSHOT_LLM__DEFAULT__RETRY_DELAY=1

# ================= LLM备用配置 =================
PENSHOT_LLM__FALLBACK__BASE_URL=https://api.deepseek.com
PENSHOT_LLM__FALLBACK__API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
PENSHOT_LLM__FALLBACK__MODEL_NAME=deepseek-chat
PENSHOT_LLM__FALLBACK__TEMPERATURE=0.1
PENSHOT_LLM__FALLBACK__TIMEOUT=60
PENSHOT_LLM__FALLBACK__MAX_TOKENS=8192


########################## 嵌入模型配置 #########################
# 系统支持的厂商（openai, qwen, HuggingFace, ollama），当默认模型不可用时使用备用厂商

# ================ 嵌入模型默认配置 ================
PENSHOT_EMBED__DEFAULT__BASE_URL=https://api.openai.com/v1
PENSHOT_EMBED__DEFAULT__API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
# 中文常用模型：gte-large-zh，bge-large-zh-v1.5，text-embedding-3-small，text-embedding-v4
PENSHOT_EMBED__DEFAULT__MODEL_NAME=text-embedding-v4
PENSHOT_EMBED__DEFAULT__DEVICE=gpu
PENSHOT_EMBED__DEFAULT__NORMALIZE_EMBEDDINGS=true
PENSHOT_EMBED__DEFAULT__DIMENSIONS=1536
PENSHOT_EMBED__DEFAULT__TIMEOUT=60

# ================ 嵌入模型备用配置 ================
PENSHOT_EMBED__FALLBACK__BASE_URL=http://localhost:11434
PENSHOT_EMBED__FALLBACK__API_KEY=
PENSHOT_EMBED__FALLBACK__MODEL_NAME=text-embedding-3-small
PENSHOT_EMBED__FALLBACK__DEVICE=gpu
PENSHOT_EMBED__FALLBACK__TIMEOUT=60


########################## 检索器配置 #########################
# 是否启用重排序
PENSHOT_RETRIEVER__RERANK_ENABLED=false
# 重排序模型名称
PENSHOT_RETRIEVER__RERANK_MODEL_NAME=BAAI/bge-reranker-large
# 本地模型路径（优先使用）
PENSHOT_RETRIEVER__RERANK_MODEL_LOCAL_PATH=./models/bge-reranker-large
# 搜索类型 (similarity/mmr)
PENSHOT_RETRIEVER__SEARCH_TYPE=similarity
# 检索文档数量
PENSHOT_RETRIEVER__SIMILARITY_TOP_K=5


########################## Redis 配置 ##########################
# Redis 单节点配置，支持使用完整的URL参数配置：PENSHOT_REDIS_URL=redis://:password@localhost:6379/0
PENSHOT_REDIS_HOST=localhost
PENSHOT_REDIS_PORT=6379
PENSHOT_REDIS_DB=0
PENSHOT_REDIS_PASSWORD=
PENSHOT_REDIS_SSL=false

# 连接池配置
PENSHOT_REDIS_MAX_CONNECTIONS=10
PENSHOT_REDIS_SOCKET_TIMEOUT=20
PENSHOT_REDIS_CONNECT_TIMEOUT=20
PENSHOT_REDIS_RETRY_ON_TIMEOUT=true
PENSHOT_REDIS_DECODE_RESPONSES=true

########################## 注意事项 ##############################
# 1. 请确保设置有效的AI API密钥
# 2. 对于中文剧本，推荐使用支持中文的模型
# 3. 调试模式会记录详细日志，可能会包含敏感信息